{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "../dist/electron",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["main.ts"],
  "exclude": ["experiments/**"]
}
