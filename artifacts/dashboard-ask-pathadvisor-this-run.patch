+        const value = mockStorage[key];
+        return value !== undefined ? value : null;
+      },
+      setItem: function (key: string, value: string): void {
+        mockStorage[key] = value;
+      },
+      removeItem: function (key: string): void {
+        delete mockStorage[key];
+      },
+      clear: function (): void {
+        mockStorage = {};
+      },
