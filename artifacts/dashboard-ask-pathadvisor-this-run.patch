+export type TravelFrequency = 'any' | 'none' | 'up-to-25' | 'up-to-50' | 'over-50';
+export type ClearanceLevel = 'none' | 'public-trust' | 'secret' | 'ts' | 'ts-sci';
+export type PositionSensitivity =
