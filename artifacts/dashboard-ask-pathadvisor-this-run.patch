+  PathAdvisorResponse,
+  PathScenario,
+} from '@/types/pathadvisor';
+
+// Store interface
+interface DashboardState {
+  // Dashboard data
+  compensation: CompensationData;
+  retirement: RetirementData;
+  leave: LeaveData;
+  fehb: FehbData;
+  tax: TaxData;
