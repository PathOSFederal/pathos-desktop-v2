+// ============================================================================
+// COMBINED STORE TYPE
+// ============================================================================
+
+export type TaskStore = TaskState & TaskActions;
+
+// ============================================================================
+// SELECTORS
+// ============================================================================
+
+/**
+ * Selector for all tasks.
