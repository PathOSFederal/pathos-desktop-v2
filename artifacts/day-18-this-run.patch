-++++      if (dayNum !== CURRENT_DAY && dayNum > CURRENT_DAY - 3) {
-++++        issues.push({
-++++          file: fileName,
-++++          lineNum: lineNum + 1,
-++++          line: line.trim(),
-++++          dayRef: dayNum,
-++++        });
-++++      }
-++++    }
-++++  }
-++++
-++++  return issues;
-++++}
-++++
-++++/**
