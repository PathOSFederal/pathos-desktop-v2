-+++++
-+++++    if (!existsSync(fileConfig.path)) {
-+++++      if (fileConfig.required) {
-+++++        console.log(`в•¬Гҙв”ңв–“в”¬в•қО“Г¶ВЈО“Г¶Гұв•¬Гҙв”ңв•ўв”¬Гәв•¬Гҙв”ңв•—в”ңв”Өв•¬Гҙв”ңв•ўв”¬в•қв•¬Гҙв”ңв–“в”¬Г‘О“ГІВјв”ңв”ӨО“Г¶ВЈО“ГІГіО“Г¶Вјв”ңв•‘О“ГІВјв”ңв”ӨО“Г¶ВЈО“ГІГіО“Г¶ВЈО“Г»ГҶв•¬Гҙв”ңв–“в”¬в•қО“Г¶ВЈО“Г¶Гұв•¬Гҙв”ңв•ўв”¬Гәв•¬Гҙв”ңв–“в”ңв”Ӯв•¬Гҙв”ңв•ўв”¬в•қО“Г¶ВЈО“ГІГҰО“ГІВјв”ңв”ӨО“Г¶ВЈО“ГІГіО“Г¶ВјО“ГІВҘв•¬Гҙв”ңв•ўв”¬Гәв•¬Гҙв”ңв–“в”ңВӘв•¬Гҙв”ңв–“в”¬в•қО“Г¶ВЈО“Г¶Гұв•¬Гҙв”ңв•ўв”¬Гәв•¬Гҙв”ңв–“в”ңв”Ӯв•¬Гҙв”ңв•ўв”¬в•қО“Г¶ВЈО“ГІГҰО“ГІВјв”ңв”ӨО“Г¶ВЈО“ГІГіО“Г¶Вјв”ңв•‘в•¬Гҙв”ңв•ўв”¬в•қО“Г¶ВЈв”¬Гӯ Warning: ${fileConfig.name} not found (skipping scan)`);
