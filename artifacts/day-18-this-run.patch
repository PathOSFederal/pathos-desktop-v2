-++++ * @returns {boolean} true if the file should be excluded
-++++ */
-++++function isExcludedPath(relativePath) {
-++++  for (let i = 0; i < excludedDirs.length; i++) {
-++++    if (relativePath.startsWith(excludedDirs[i])) {
-++++      return true;
-++++    }
-++++  }
