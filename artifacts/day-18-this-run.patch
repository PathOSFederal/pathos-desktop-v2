--++++    steps:
--++++      # ----------------------------------------------------------------------
--++++      # SETUP
--++++      # ----------------------------------------------------------------------
--++++
--++++      - name: Checkout code
--++++        uses: actions/checkout@v4
--++++
--++++      # Use Node.js LTS (22.x)
--++++      - name: Setup Node.js
--++++        uses: actions/setup-node@v4
--++++        with:
--++++          node-version: '22'
--++++
--++++      # Setup pnpm with corepack-style action
--++++      - name: Setup pnpm
--++++        uses: pnpm/action-setup@v4
--++++        with:
--++++          version: 9
--++++
--++++      # Cache pnpm store for faster installs
--++++      - name: Get pnpm store directory
--++++        shell: bash
--++++        run: |
