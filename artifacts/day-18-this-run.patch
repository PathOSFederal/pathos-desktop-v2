+++++# ============================================================================
+++++# CI DEVELOP WORKFLOW - PathOS Tier 1 Frontend
+++++# ============================================================================
+++++#
+++++# PURPOSE:
+++++# Enforces Definition of Done (DoD) policy for PRs targeting develop.
+++++# This workflow adds policy validation on top of standard quality gates:
+++++#   1. Policy validation (ci:validate) - day artifacts, change briefs, labels
+++++#   2. Linting (ESLint) - catches style issues and potential bugs
+++++#   3. Type checking (TypeScript) - catches type errors
+++++#   4. Unit tests (Vitest) - catches logic errors and regressions
+++++#   5. Build (Next.js) - ensures the app compiles successfully
+++++#
+++++# WHEN IT RUNS:
+++++# - On pull requests targeting the 'develop' branch
+++++#
+++++# POLICY REQUIREMENTS (enforced by ci:validate):
+++++# - Day patch artifacts must exist (artifacts/day-XX.patch, day-XX-this-run.patch)
+++++# - Change brief must exist (docs/change-briefs/day-XX.md)
+++++# - Day labels must be consistent (no mismatched day references)
+++++#
+++++# ============================================================================
+++++
+++++name: CI Develop
+++++
+++++on:
+++++  # Run on PRs targeting develop only
+++++  pull_request:
+++++    branches:
+++++      - develop
+++++
+++++# Cancel in-progress runs for the same PR
+++++concurrency:
+++++  group: ${{ github.workflow }}-${{ github.ref }}
+++++  cancel-in-progress: true
+++++
+++++jobs:
+++++  # ==========================================================================
+++++  # QUALITY + POLICY CHECKS
+++++  # ==========================================================================
+++++  # Single job that runs all checks in sequence.
+++++  # Policy validation runs first to fail fast if DoD requirements are missing.
+++++
+++++  quality:
+++++    name: Policy + Quality Gates
+++++    runs-on: ubuntu-latest
+++++
+++++    steps:
+++++      # ----------------------------------------------------------------------
+++++      # SETUP
+++++      # ----------------------------------------------------------------------
+++++
+++++      - name: Checkout code
+++++        uses: actions/checkout@v4
+++++
+++++      # Use Node.js LTS (22.x)
+++++      - name: Setup Node.js
+++++        uses: actions/setup-node@v4
+++++        with:
+++++          node-version: '22'
+++++
+++++      # Setup pnpm with corepack-style action
+++++      - name: Setup pnpm
+++++        uses: pnpm/action-setup@v4
+++++        with:
+++++          version: 9
+++++
+++++      # Cache pnpm store for faster installs
+++++      - name: Get pnpm store directory
+++++        shell: bash
+++++        run: |
+++++          echo "STORE_PATH=$(pnpm store path --silent)" >> $GITHUB_ENV
+++++
+++++      - name: Setup pnpm cache
+++++        uses: actions/cache@v4
+++++        with:
+++++          path: ${{ env.STORE_PATH }}
+++++          key: ${{ runner.os }}-pnpm-store-${{ hashFiles('**/pnpm-lock.yaml') }}
+++++          restore-keys: |
+++++            ${{ runner.os }}-pnpm-store-
+++++
+++++      # Install dependencies
+++++      - name: Install dependencies
+++++        run: pnpm install --frozen-lockfile
+++++
+++++      # ----------------------------------------------------------------------
+++++      # POLICY VALIDATION (fail fast if DoD requirements missing)
+++++      # ----------------------------------------------------------------------
+++++
+++++      - name: Validate DoD requirements (ci:validate)
+++++        run: pnpm ci:validate
+++++
+++++      # ----------------------------------------------------------------------
+++++      # QUALITY CHECKS
+++++      # ----------------------------------------------------------------------
+++++
+++++      # Step 1: Lint
+++++      # Catches style issues, potential bugs, and enforces coding standards.
+++++      - name: Lint
+++++        run: pnpm lint
+++++
+++++      # Step 2: Type Check
+++++      # Catches TypeScript type errors without emitting files
+++++      - name: Type Check
+++++        run: pnpm typecheck
+++++
+++++      # Step 3: Unit Tests
+++++      # Runs all Vitest tests to catch logic errors and regressions
+++++      - name: Test
+++++        run: pnpm test
+++++
+++++      # Step 4: Build
+++++      # Ensures the Next.js app compiles successfully for production
+++++      - name: Build
+++++        run: pnpm build
