-+++++import { existsSync, readFileSync, readdirSync } from 'fs';
-+++++import { resolve, dirname } from 'path';
-+++++import { fileURLToPath } from 'url';
-+++++
-+++++// ----------------------------------------------------------------------------
-+++++// CONFIGURATION
