+        </div>
+      )}
+
+      {successMessage !== '' && (
+        <div className="bg-green-500/10 border border-green-500/30 text-green-400 text-sm p-3 rounded-lg">
+          {successMessage}
+        </div>
+      )}
+
+      {/* ================================================================== */}
+      {/* SECTION 1: PASTE AN EMAIL (RECOMMENDED) */}
+      {/* ================================================================== */}
