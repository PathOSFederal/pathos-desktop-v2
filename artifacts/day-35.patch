+      title: 'Save your first search',
+      description: 'Save a job search to track roles that match your criteria.',
+      severity: 'medium',
+      ctaLabel: 'Go to Job Search',
+      ctaAction: function () {
+        router.push('/dashboard/job-search');
+      },
+      icon: Search,
+    });
+  }
+
+  // Alert 4: No alerts configured
+  if (alerts.length === 0) {
