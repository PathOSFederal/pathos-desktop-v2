+  /**
+   * Handle suggested prompt click.
+   * Day 42 Fix: Use sidebar mode instead of expanded mode for Ask CTAs.
+   * Ask PathAdvisor buttons should update the existing sidebar, not open Focus Mode.
+   * 
+   * Sets context to 'scenario' with scenarioType: 'benefits' to ensure PathAdvisor knows
+   * it's in Benefits workspace mode.
+   * 
+   * NOTE: openPathAdvisor calls setContext internally with just {source: 'scenario'}, which
+   * would overwrite scenarioType and scenarioId. To preserve these fields, we wrap setContext
+   * to always merge in scenarioType: 'benefits' and scenarioId, ensuring they're never lost.
+   * 
+   * @param prompt - The contextual prompt text to inject into PathAdvisor
+   * @param intent - Optional intent identifier (defaults to 'benefits_workspace_question')
+   * @param cardName - Optional name of the card that triggered this request (for context)
+   */
+  function handleSuggestedPrompt(prompt: string, intent?: string, cardName?: string) {
+    // Day 42 Fix: Capture current scenario ID for use in wrapper
+    const scenarioIdValue = activeScenarioId;
+    
+    // Day 42 Fix: Set context FIRST with all required fields
+    // This ensures the context is set correctly from the start
+    advisorContext.setContext({
+      source: 'scenario',
+      scenarioType: 'benefits',
+      scenarioId: scenarioIdValue,
+    });
+    
+    // Day 42 Fix: Create a wrapper for setContext that always includes scenarioType and scenarioId
+    // openPathAdvisor calls setContext internally with just {source: 'scenario'}, but we need to preserve
+    // scenarioType: 'benefits' and scenarioId. The wrapper merges these fields into every setContext call.
+    const wrappedSetContext = function (newContext: Parameters<typeof advisorContext.setContext>[0]) {
+      // Always merge in scenarioType and scenarioId, preserving other fields from newContext
+      advisorContext.setContext({
+        ...newContext,
+        scenarioType: 'benefits',
+        scenarioId: scenarioIdValue,
+      });
+    };
+    
+    // Day 42 Fix: Build enhanced prompt with context if cardName provided
+    let enhancedPrompt = prompt;
+    if (cardName) {
+      const context = buildBenefitsAskContext(cardName);
+      enhancedPrompt = `${context}\n\n${prompt}`;
+    }
+    
+    // Day 42 Fix: Use canonical openPathAdvisor helper with wrapped setContext
+    // Source must be 'scenario' (valid AdvisorContextData source) for Benefits workspace
+    // Use 'sidebar' mode to open PathAdvisor sidebar panel (NOT Focus Mode)
+    // Ask CTAs should update the existing sidebar, not open the center modal
+    openPathAdvisor({
+      intent: intent !== undefined ? intent : 'benefits_workspace_question',
+      source: 'scenario',
+      prompt: enhancedPrompt,
+      openMode: 'sidebar', // Day 42 Fix: Changed from 'expanded' to 'sidebar' for Ask CTAs
+      closeOverlays: false,
+      contextFunctions: {
+        setContext: wrappedSetContext,
+        setPendingPrompt: advisorContext.setPendingPrompt,
+        setIsPanelOpen: advisorContext.setIsPanelOpen,
+        setShouldOpenFocusMode: advisorContext.setShouldOpenFocusMode,
+        setOnPathAdvisorClose: advisorContext.setOnPathAdvisorClose,
+      },
+    });
+  }
