@@ -168,3 +168,116 @@
   /* Smooth transition for when the class is removed */
   transition: box-shadow 0.3s ease-out, background-color 0.3s ease-out;
 }
+
+/* ============================================================================
+   ROUTE TRANSITIONS (Day 35)
+   ============================================================================
+   
+   PURPOSE:
+   Provides subtle fade + slide transitions when navigating between routes.
+   Only animates main content region, leaving sidebar/header static.
+   
+   HOW IT WORKS:
+   1. RouteTransition component wraps main content
+   2. On route change, applies exit animation (fade out + slide down)
+   3. New content enters with fade in + slide up
+   4. Respects prefers-reduced-motion (instant transition if preferred)
+   
+   STYLING:
+   - Subtle opacity + translateY animation (8-12px)
+   - 200ms duration for smooth but quick transition
+   - Ease-out timing for natural feel
+   
+   @version Day 35 - Route Transitions
+============================================================================ */
+.route-transition {
+  /* Base transition properties */
+  transition: opacity 200ms ease-out, transform 200ms ease-out;
+}
+
+.route-transition-enter {
+  /* Initial state: slightly below and transparent */
+  opacity: 0;
+  transform: translateY(10px);
+  
+  /* Animate to visible */
+  animation: route-enter 200ms ease-out forwards;
+}
+
+.route-transition-exit {
+  /* Exit state: fade out and slide down slightly */
+  opacity: 0;
+  transform: translateY(-8px);
+}
+
+.route-transition-instant {
+  /* For reduced motion: instant transition, no animation */
+  opacity: 1;
+  transform: translateY(0);
+}
+
+@keyframes route-enter {
+  from {
+    opacity: 0;
+    transform: translateY(10px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+/* ============================================================================
+   GUIDED HANDOFF HIGHLIGHTS (Day 35)
+   ============================================================================
+   
+   PURPOSE:
+   Provides visual feedback when PathAdvisor guides user to a specific section.
+   Applied temporarily (~1500ms) to elements with data-handoff-target attribute.
+   
+   HOW IT WORKS:
+   1. PathAdvisor navigates with ?handoff=<id> query param
+   2. scrollAndPulse() finds element with matching data-handoff-target
+   3. Applies highlight class (pulse or static based on motion preference)
+   4. Removes class after duration
+   
+   STYLING:
+   - Pulse: Subtle glow ring + background pulse animation
+   - Static: Simple highlight for reduced motion users
+   - Uses accent color for consistency
+   
+   @version Day 35 - Guided Handoff
+============================================================================ */
+.handoff-highlight-pulse {
+  /* Ring effect using box-shadow */
+  box-shadow: 0 0 0 3px var(--ring);
+  
+  /* Subtle background tint */
+  background-color: color-mix(in oklch, var(--accent) 10%, transparent);
+  
+  /* Pulse animation */
+  animation: handoff-pulse 1500ms ease-out;
+}
+
+.handoff-highlight-static {
+  /* Static highlight for reduced motion users */
+  box-shadow: 0 0 0 3px var(--ring);
+  background-color: color-mix(in oklch, var(--accent) 10%, transparent);
+  
+  /* No animation, just static highlight */
+}
+
+@keyframes handoff-pulse {
+  0% {
+    box-shadow: 0 0 0 3px var(--ring);
+    background-color: color-mix(in oklch, var(--accent) 10%, transparent);
+  }
+  50% {
+    box-shadow: 0 0 0 6px var(--ring);
+    background-color: color-mix(in oklch, var(--accent) 15%, transparent);
+  }
+  100% {
+    box-shadow: 0 0 0 3px var(--ring);
+    background-color: color-mix(in oklch, var(--accent) 10%, transparent);
+  }
+}
