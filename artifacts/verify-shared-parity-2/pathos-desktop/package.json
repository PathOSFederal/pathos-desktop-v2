{
  "name": "pathos-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PATHOS_DESKTOP_DEV=1 electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pathos.desktop",
    "productName": "PathOS Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "renderer/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "artifactName": "pathos-setup.${ext}"
    }
  }
}
