+  );
+}
+
+/**
+ * Trust boundary microcopy and OPSEC details.
+ */
+function TrustBoundaryPanel() {
+  return (
+    <Card className="border-border/60 p-4">
+      <div className="flex items-start gap-3">
+        <ShieldCheck className="h-5 w-5 text-amber-400 mt-0.5" />
