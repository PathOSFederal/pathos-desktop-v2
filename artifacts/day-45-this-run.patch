+            <p className="text-xs text-muted-foreground mt-1">
+              Used to tailor explanations. Stored locally in your browser only.
+            </p>
+
+            <div className="mt-4 space-y-4">
+              <div className="space-y-2">
+                <Label>Target GS level</Label>
+                <Input
