+    const reminderCopy: TaskReminder = {
+      enabled: task.reminder.enabled,
+      remindAt: task.reminder.remindAt,
+      repeat: task.reminder.repeat,
+    };
+    const taskCopy: Task = Object.assign({}, task, {
+      reminder: reminderCopy,
+    });
+    copy.push(taskCopy);
+  }
+  return copy;
+}
